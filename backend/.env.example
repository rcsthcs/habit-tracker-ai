# Habit App — Environment Variables
# Copy to .env and fill in values

DATABASE_URL=sqlite+aiosqlite:///./habits.db        # Production: postgresql+asyncpg://user:pass@host/db
SECRET_KEY=change-me-to-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
BACKEND_PUBLIC_URL=http://localhost:8000

# SMTP (email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Habit Tracker AI
SMTP_USE_TLS=true
EMAIL_VERIFY_TOKEN_TTL_HOURS=24

# Firebase Admin (FCM push)
FIREBASE_SERVICE_ACCOUNT_FILE=/absolute/path/to/firebase-service-account.json

OLLAMA_BASE_URL=http://localhost:11434               # Production: https://api.openai.com/v1
OLLAMA_MODEL=llama3.2                                # Production: gpt-4

