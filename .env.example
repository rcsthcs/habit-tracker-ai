# ========================
# Habit Tracker AI — .env
# ========================

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/habits.db

# Auth
SECRET_KEY=super-secret-dev-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
BACKEND_PUBLIC_URL=http://localhost:8000

# SMTP (email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Habit Tracker AI
SMTP_USE_TLS=true
EMAIL_VERIFY_TOKEN_TTL_HOURS=24

# Firebase Admin (FCM push)
FIREBASE_SERVICE_ACCOUNT_FILE=/absolute/path/to/firebase-service-account.json

# LLM (Ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3n:e4b

# LLM (OpenRouter)
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=stepfun/step-3.5-flash:free
